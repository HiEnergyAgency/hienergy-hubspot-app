# HubSpot developer CLI (hs auth)
# Create app at https://app.hubspot.com/developer

# Hi Energy — per-portal credentials (set in HubSpot app secrets for production)
HIENERGY_API_KEY=
HIENERGY_MCP_URL=https://app.hienergy.ai/mcp
HIENERGY_APP_ORIGIN=https://app.hienergy.ai

# Optional: Auth0 for Hi Energy (if using bearer tokens instead of API key)
HIENERGY_AUTH0_DOMAIN=
HIENERGY_AUTH0_CLIENT_ID=
HIENERGY_AUTH0_CLIENT_SECRET=
HIENERGY_AUTH0_AUDIENCE=https://api.hienergyrocket.com/mcp

# HubSpot OAuth (Marketplace app — configure in developer account)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/oauth/callback
