    "permittedUrls": {
      "fetch": [
        "https://api.hubapi.com",
        "https://app.hienergy.ai",
        "https://api.hienergyrocket.com"
      ],
      "img": [
        "https://app.hienergy.ai",
        "https://lh3.googleusercontent.com"
      ],
      "iframe": []
    },
    "support": {
      "supportEmail": "support@hienergy.ai",
      "documentationUrl": "https://app.hienergy.ai/api_documentation/mcp",
      "supportUrl": "https://app.hienergy.ai"
    }
  }
