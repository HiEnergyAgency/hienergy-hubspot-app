# Copy to scripts/deploy-breeze.env (gitignored) or export before deploy.
# Required for production HubSpot webhook service.

DEPLOY_BASE_URL=https://app.hienergy.ai
RENDER_SERVICE_NAME=hienergy-hubspot-breeze

HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://app.hienergy.ai/hubspot/oauth/callback

HIENERGY_API_BASE=https://app.hienergy.ai/api/v1
HIENERGY_MCP_URL=https://app.hienergy.ai/mcp
HIENERGY_APP_ORIGIN=https://app.hienergy.ai

# Use internal lookup API OR file store (Render disk path below).
HIENERGY_HUBSPOT_PORTAL_LOOKUP_URL=
HIENERGY_HUBSPOT_PORTAL_LOOKUP_TOKEN=
HIENERGY_HUBSPOT_PORTAL_STORE=/var/data/hubspot-portals.json

# Optional Docker registry push (for ./scripts/deploy-breeze.sh docker push)
DOCKER_IMAGE=ghcr.io/hienergyagency/hienergy-hubspot-breeze:latest
